<?xml version="1.0" encoding="utf-8"?>
<!--
  Microsoft.Testing.Platform code coverage settings, applied via the
  "coverage-settings" option in CI. See docs/decisions/019-code-coverage-scope.md
  for the reasoning.
-->
<Configuration>
    <CodeCoverage>
        <ModulePaths>
            <Exclude>
                <!-- Test scaffolding, not a system under test. -->
                <ModulePath>.*Shoplists\.Testing\.Common\.dll$</ModulePath>
            </Exclude>
        </ModulePaths>
        <Attributes>
            <Exclude>
                <!--
          Exclude truly generated code marked with [GeneratedCode]: StronglyTypedId IDs (+
          their converters), Mediator registrations, ...
          NOTE: EF Core migrations are NOT marked [GeneratedCode] and are handled
          separately under Functions below. Do NOT add CompilerGeneratedAttribute here;
          that would also drop async/await, yield, and lambda code from real methods.
        -->
                <Attribute>^System\.CodeDom\.Compiler\.GeneratedCodeAttribute$</Attribute>
                <Attribute>^System\.Diagnostics\.CodeAnalysis\.ExcludeFromCodeCoverageAttribute$</Attribute>
                <Attribute>^System\.Diagnostics\.DebuggerHiddenAttribute$</Attribute>
                <Attribute>^System\.Diagnostics\.DebuggerNonUserCodeAttribute$</Attribute>
            </Exclude>
        </Attributes>
        <Functions>
            <Exclude>
                <!--
          Infrastructure that is not meaningfully unit-testable, excluded by intent
          (ADR 019), matched by fully-qualified name: EF Core migrations (Up/Down; they
          are not [GeneratedCode]) and the design-time DbContext factory used only by the
          EF CLI at design time, never at runtime.
        -->
                <Function>^Shoplists\.Persistence\.Migrations\..*</Function>
                <Function>^Shoplists\.Persistence\.DesignTimeDbContextFactory.*</Function>
            </Exclude>
        </Functions>
    </CodeCoverage>
</Configuration>
